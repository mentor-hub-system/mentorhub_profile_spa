{
  "name": "template_spa",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "cypress": "cypress open",
    "cypress:run": "cypress run",
    "api": "mh down && mh up profile_api",
    "service": "mh down && mh up profile && npm run open",
    "container": "DOCKER_BUILDKIT=0 docker build --build-arg GITHUB_TOKEN=\"${GITHUB_TOKEN:-${NODE_AUTH_TOKEN}}\" -t ghcr.io/mentor-hub-system/mentorhub_profile_spa:latest .",
    "push": "docker push ghcr.io/mentor-hub-system/mentorhub_profile_spa:latest",
    "open": "open -a 'Google Chrome' 'http://localhost:8388' || google-chrome 'http://localhost:8388' || exg-open 'localhost:8388'",
    "build-publish": "npm install --include=dev && npm run container && npm run push",
    "build-package": "npm install --include=dev && npm run container",
    "publish-package": "npm run push",
    "delete-package": "gh api -X DELETE /orgs/mentor-hub-system/packages/container/mentorhub_profile_spa"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@mentor-hub-system/mentorhub_spa_utils": "github:mentor-hub-system/mentorhub_spa_utils#main",
    "@tanstack/vue-query": "^5.59.0",
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vuetify": "^3.11.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^3.0.5",
    "@vitest/ui": "^3.0.5",
    "@vue/test-utils": "^2.4.6",
    "cypress": "^15.8.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.9.2",
    "vite": "^7.2.0",
    "vitest": "^3.0.5",
    "vue-tsc": "^2.2.0"
  },
  "overrides": {
    "glob": "^13.0.6",
    "qs": "^6.14.1"
  }
}